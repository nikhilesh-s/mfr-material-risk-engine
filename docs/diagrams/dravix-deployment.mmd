    DATA[(Dataset Storage)] -. lookup data / metadata .-> INF
    TRAIN[Future Training Pipeline<br/>offline, not part of v0.3.0 runtime] -. artifact refresh .-> MODEL
    TRAIN -. dataset preparation .-> DATA

